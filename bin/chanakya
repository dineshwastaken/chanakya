#!/usr/bin/env bash
#
# Chanakya control CLI - the single entry point for the framework.
#
set -euo pipefail

# Find the script's directory and load libraries
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE_ROOT="$(cd "$BIN_DIR/.." && pwd)"

# Constants
PONYTAIL_REPO="https://github.com/DietrichGebert/ponytail"

# Load libraries (order matters)
# If we are running from the engine root, use its lib/
# If we are running from a consumer's .chanakya/bin/, use that lib/
source "$ENGINE_ROOT/lib/ui.sh"
source "$ENGINE_ROOT/lib/common.sh"
source "$ENGINE_ROOT/lib/version.sh"

# --- Preflight --------------------------------------------------------------------------------

cmd_doctor() {
  step "Checking prerequisites"
  local missing=0
  local tools=("git" "bash" "grep" "sed" "find" "awk" "wc" "tr")
  
  for t in "${tools[@]}"; do
    if has_tool "$t"; then
      ok "$t found"
    else
      bad "$t missing"
      missing=1
    fi
  done
  
  if [ "$missing" -eq 1 ]; then
    echo
    bad "Missing essential tools. Installation guidance:"
    info "macOS:  Install Xcode Command Line Tools: xcode-select --install"
    info "Linux:  Use your package manager (apt/yum/dnf) to install git and build-essential."
    info "Windows: Install Git for Windows and run this inside 'Git Bash'."
    return 1
  fi
  ok "All tools present."
}

# --- Status & Assessment ----------------------------------------------------------------------

cmd_status() {
  cmd_doctor || return 1
  echo
  printf "Chanakya %s\n" "$(get_version)"
  echo
  
  step "Project"
  local br; br="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "(not a git repo)")"
  info "Branch: $br"
  
  if [ -d "$CHANAKYA_DIR/state" ]; then
    local s; s="$(find "$CHANAKYA_DIR/state" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
    ok "State: $s files"
  fi

  step "Health"
  local n; n="$(find "$CHANAKYA_DIR/knowledge" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
  info "Knowledge: $n files"
  if [ -f "$CHANAKYA_DIR/canary.md" ]; then ok "Canary: present"; else warn "Canary: missing"; fi
  
  resolve_engine
  step "Framework"
  info "Source: $ENGINE_URL @ $ENGINE_REF"
}

cmd_assess() {
  step "Assessment"
  local k_dir="$CHANAKYA_DIR/knowledge"
  if [ ! -d "$k_dir" ]; then bad "No knowledge bundle found."; return 1; fi
  
  local words; words="$(find "$k_dir" -name '*.md' -exec cat {} + 2>/dev/null | wc -w | tr -d ' ')"
  local tokens=$(( words * 13 / 10 ))
  local files; files="$(find "$k_dir" -name '*.md' | wc -l | tr -d ' ')"
  
  info "Distilled bundle: ~$tokens tokens ($files files)"
  info "This bundle replaces thousands of raw files (~500MB+) with high-signal context."
  ok "Framework benefit: High (reduces noise by >95%)"
}

# --- Maintenance ------------------------------------------------------------------------------

cmd_update_framework() {
  local check_only=${1:-0}
  resolve_engine
  
  step "Checking for engine updates"
  info "Engine Source: $ENGINE_URL @ $ENGINE_REF"
  
  if [ "$check_only" -eq 1 ]; then
    # Simple check: compare local VERSION with remote (this is a bit complex for shell without fetch)
    # For now, just report what we have and what we track.
    info "Local version: $(get_version)"
    info "Tracking branch/ref: $ENGINE_REF"
    return 0
  fi
  
  if confirm "Sync framework files from $ENGINE_REF?"; then
    local tmp_dir; tmp_dir="/tmp/chanakya-update-$(date +%s)"
    info "Downloading to temporary folder..."
    git clone --depth 1 --branch "$ENGINE_REF" "$ENGINE_URL" "$tmp_dir" >/dev/null 2>&1 || {
      bad "Failed to download $ENGINE_REF from $ENGINE_URL."
      return 1
    }
    
    info "Syncing framework files to .chanakya/..."
    # Sync engine-owned directories
    mkdir -p "$CHANAKYA_DIR/bin" "$CHANAKYA_DIR/lib" "$CHANAKYA_DIR/templates" "$CHANAKYA_DIR/docs"
    cp -r "$tmp_dir/bin/." "$CHANAKYA_DIR/bin/"
    cp -r "$tmp_dir/lib/." "$CHANAKYA_DIR/lib/"
    cp -r "$tmp_dir/templates/." "$CHANAKYA_DIR/templates/"
    cp -r "$tmp_dir/docs/." "$CHANAKYA_DIR/docs/"
    cp "$tmp_dir/VERSION" "$CHANAKYA_DIR/"
    cp "$tmp_dir/CHANGELOG.md" "$CHANAKYA_DIR/"
    cp "$tmp_dir/LICENSE" "$CHANAKYA_DIR/"
    
    # Optionally refresh the shim
    if [ -f "$REPO_ROOT/chanakya" ]; then
      if diff -q "$tmp_dir/templates/chanakya" "$REPO_ROOT/chanakya" >/dev/null 2>&1; then
        : # identical
      else
        if confirm "Refresh root 'chanakya' shim?"; then
          cp "$tmp_dir/templates/chanakya" "$REPO_ROOT/chanakya"
          chmod +x "$REPO_ROOT/chanakya"
          ok "Shim refreshed."
        fi
      fi
    fi
    
    rm -rf "$tmp_dir"
    ok "Framework updated to latest $ENGINE_REF. (No project files were changed)"
  fi
}

cmd_update() {
  step "Project Health Pass"
  cmd_doctor || return 1
  echo
  
  local issues=0
  
  # 1. Source Paths
  step "Source Paths"
  grep -E "^[[:space:]]+source:" "$CHANAKYA_DIR/manifest.yaml" 2>/dev/null | sed -E 's/.*source:[[:space:]]*//' | while read -r src; do
    local val; val="$(prop_value "$src")"
    if [ -z "$val" ] || [ ! -e "$val" ]; then
      bad "$src is invalid or missing: $val"
      issues=$((issues + 1))
    else
      ok "$src -> $val"
    fi
  done
  
  # 2. Knowledge Coverage
  step "Knowledge Coverage"
  local n; n="$(find "$CHANAKYA_DIR/knowledge" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
  if [ "$n" -eq 0 ]; then
    warn "No distilled knowledge found. Run 'chanakya produce <section>'."
    issues=$((issues + 1))
  else
    ok "Knowledge: $n files"
  fi
  
  # 3. Canary
  step "Canary"
  if [ ! -f "$CHANAKYA_DIR/canary.md" ]; then
    warn "Canary missing."
    issues=$((issues + 1))
  else
    ok "Canary: present"
  fi
  
  # 4. Rules & Skills
  step "Governance"
  if [ ! -f "$REPO_ROOT/.cursor/rules/chanakya.mdc" ]; then
    warn "Always-on rule missing."
    issues=$((issues + 1))
  else
    ok "Rule: present"
  fi
  
  # 5. Local State
  step "State"
  if [ -d "$CHANAKYA_DIR/state" ]; then
    local s; s="$(find "$CHANAKYA_DIR/state" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
    ok "Local state: $s files"
  else
    info "Local state: none"
  fi
  
  # 6. Framework Status
  resolve_engine
  info "Version: $(get_version)"
  info "Source:  $ENGINE_URL @ $ENGINE_REF"
  
  echo
  if [ "$issues" -gt 0 ]; then
    bad "Project health pass found $issues issues."
    return 1
  else
    ok "Project health is clean."
  fi
}

cmd_suggest_commit() {
  step "Commit Suggestions"
  echo "Chanakya suggests staging these framework files for your team:"
  echo
  local files="chanakya .cursor/rules/chanakya.mdc .gitignore"
  [ -f "$REPO_ROOT/.cursor/rules/ponytail.mdc" ] && files="$files .cursor/rules/ponytail.mdc"
  
  # Check for skills if they exist
  if [ -d "$REPO_ROOT/.cursor/skills" ]; then
    local skills; skills="$(find "$REPO_ROOT/.cursor/skills" -name "chanakya-*" -type d 2>/dev/null)"
    if [ -n "$skills" ]; then
      files="$files .cursor/skills/chanakya-*"
    fi
  fi
  
  printf "  ${C_CYAN}git add $files${C_RESET}\n"
  echo
  info "Reason: These are the minimal governance files needed to share Chanakya."
  warn "Do NOT commit .chanakya/ or .chanakya.json."
}

cmd_uninstall() {
  step "Uninstalling Chanakya"
  warn "This will remove .chanakya/, the rule, the shim, and any local state."
  if confirm "Are you sure you want to uninstall?"; then
    rm -rf "$CHANAKYA_DIR"
    rm -f "$REPO_ROOT/chanakya"
    rm -f "$REPO_ROOT/.chanakya.json"
    rm -f "$REPO_ROOT/.cursor/rules/chanakya.mdc"
    rm -f "$REPO_ROOT/.cursor/rules/chanakya.mdc.off"
    
    ok "Uninstalled. You may want to clean up your .gitignore manually."
  fi
}

# --- Lifecycle --------------------------------------------------------------------------------

cmd_enable()  { mv "$REPO_ROOT/.cursor/rules/chanakya.mdc.off" "$REPO_ROOT/.cursor/rules/chanakya.mdc" 2>/dev/null && ok "Chanakya enabled." || warn "Already enabled or rule missing."; }
cmd_disable() { mv "$REPO_ROOT/.cursor/rules/chanakya.mdc" "$REPO_ROOT/.cursor/rules/chanakya.mdc.off" 2>/dev/null && ok "Chanakya disabled." || warn "Already disabled or rule missing."; }

# ... init, scan, produce to be added next ...

# --- Knowledge Production --------------------------------------------------------

cmd_produce() {
  cmd_doctor || return 1
  step "Knowledge Production"
  local section=${1:-""}
  if [ -z "$section" ]; then
    bad "Usage: chanakya produce <section_name> (e.g. adapt, sdk, def)"
    return 1
  fi
  
  info "Validating source paths..."
  # Try to find the source for this section in the manifest
  local src; src="$(grep -A 5 "$section:" "$CHANAKYA_DIR/manifest.yaml" | grep "source:" | head -1 | sed -E 's/.*source:[[:space:]]*//')"
  if [ -z "$src" ]; then
    warn "Section '$section' not found in manifest. Assuming generic production."
  else
    local val; val="$(prop_value "$src")"
    if [ -z "$val" ] || [ ! -e "$val" ]; then
      bad "Source path for '$src' is invalid: $val"
      info "Edit $CHANAKYA_DIR/repo-paths.properties to fix."
      return 1
    fi
  fi
  
  echo
  info "Follow the instructions in .chanakya/templates/producer-prompt.md"
  info "Replace SECTION with '$section' in the prompt."
  echo
  cat "$CHANAKYA_DIR/templates/producer-prompt.md" | sed "s/SECTION/$section/g"
}

# --- Reconcile & Init -------------------------------------------------------------------------

# scan: Inventory and planned actions
cmd_scan() {
  step "Reconciling artifacts"
  local items=("engine" "manifest" "paths" "rule" "ponytail" "canary" "knowledge" "shim")
  local total=${#items[@]}
  local i=1
  
  for item in "${items[@]}"; do
    progress "$i" "$total" "Scanning $item..."
    case "$item" in
      engine)
        if [ -d "$CHANAKYA_DIR" ]; then ok "Engine: present at .chanakya/"; else warn "Engine: missing"; fi ;;
      manifest)
        if [ -f "$CHANAKYA_DIR/manifest.yaml" ]; then ok "Manifest: present"; else warn "Manifest: missing"; fi ;;
      paths)
        if [ -f "$CHANAKYA_DIR/repo-paths.properties" ]; then ok "Paths: present"; else warn "Paths: missing"; fi ;;
      rule)
        if [ -f "$REPO_ROOT/.cursor/rules/chanakya.mdc" ]; then ok "Chanakya Rule: present"; else warn "Chanakya Rule: missing"; fi ;;
      ponytail)
        if [ -f "$REPO_ROOT/.cursor/rules/ponytail.mdc" ]; then ok "Ponytail Rule: present"; else info "Ponytail Rule: not installed (optional)"; fi ;;
      canary)
        if [ -f "$CHANAKYA_DIR/canary.md" ]; then ok "Canary: present"; else warn "Canary: missing"; fi ;;
      knowledge)
        local n; n="$(find "$CHANAKYA_DIR/knowledge" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
        if [ "$n" -gt 0 ]; then ok "Knowledge: $n files"; else warn "Knowledge: empty"; fi ;;
      shim)
        if [ -f "$REPO_ROOT/chanakya" ]; then ok "Shim: present"; else warn "Shim: missing"; fi ;;
    esac
    i=$((i+1))
  done
}

cmd_init() {
  cmd_doctor || return 1
  step "Initializing Chanakya"
  
  # 1. Engine clone
  if [ ! -d "$CHANAKYA_DIR" ]; then
    resolve_engine
    info "Preparing to clone engine: $ENGINE_URL @ $ENGINE_REF"
    if confirm "Clone engine into .chanakya/?"; then
      git_safe clone --depth 1 --branch "$ENGINE_REF" "$ENGINE_URL" "$CHANAKYA_DIR" || {
        bad "Clone failed. Check your network or source settings."
        return 1
      }
    fi
  fi

  # 2. Footprint (Shim)
  if [ ! -f "$REPO_ROOT/chanakya" ]; then
    if confirm "Install Chanakya shim to project root?"; then
      cp "$CHANAKYA_DIR/templates/chanakya" "$REPO_ROOT/chanakya"
      chmod +x "$REPO_ROOT/chanakya"
      ok "Shim installed."
    fi
  fi
  
  # 3. Manifest
  if [ ! -f "$CHANAKYA_DIR/manifest.yaml" ]; then
    if confirm "Seed manifest.yaml?"; then
      local v; v="$(cat "$CHANAKYA_DIR/VERSION" 2>/dev/null || echo "0.0.0")"
      sed "s/{{VERSION}}/$v/g" "$CHANAKYA_DIR/templates/manifest.yaml" > "$CHANAKYA_DIR/manifest.yaml"
      ok "Manifest seeded."
    fi
  fi

  # 4. Footprint (Rule)
  if [ ! -f "$REPO_ROOT/.cursor/rules/chanakya.mdc" ]; then
    if confirm "Install always-on Cursor rule?"; then
      mkdir -p "$REPO_ROOT/.cursor/rules"
      cp "$CHANAKYA_DIR/templates/rules/chanakya.mdc" "$REPO_ROOT/.cursor/rules/chanakya.mdc"
      ok "Chanakya rule installed."
    fi
  fi

  if [ ! -d "$REPO_ROOT/.cursor/skills/chanakya-plan" ]; then
    if confirm "Install Chanakya Cursor skills?"; then
      mkdir -p "$REPO_ROOT/.cursor/skills/chanakya-plan"
      mkdir -p "$REPO_ROOT/.cursor/skills/chanakya-implement"
      cp "$CHANAKYA_DIR/templates/skills/chanakya-plan/SKILL.md" "$REPO_ROOT/.cursor/skills/chanakya-plan/SKILL.md"
      cp "$CHANAKYA_DIR/templates/skills/chanakya-implement/SKILL.md" "$REPO_ROOT/.cursor/skills/chanakya-implement/SKILL.md"
      ok "Chanakya skills installed."
    fi
  fi
  
  if [ ! -f "$REPO_ROOT/.cursor/rules/ponytail.mdc" ]; then
    if confirm "Install original Ponytail (lazy senior dev) rule from GitHub?" "default_y"; then
      mkdir -p "$REPO_ROOT/.cursor/rules"
      mkdir -p "$CHANAKYA_DIR/vendor"
      info "Fetching Ponytail from $PONYTAIL_REPO..."
      if [ -d "$CHANAKYA_DIR/vendor/ponytail" ]; then
        git_safe -C "$CHANAKYA_DIR/vendor/ponytail" pull origin main
      else
        git_safe clone --depth 1 "$PONYTAIL_REPO" "$CHANAKYA_DIR/vendor/ponytail"
      fi
      
      if [ -f "$CHANAKYA_DIR/vendor/ponytail/.cursor/rules/ponytail.mdc" ]; then
        cp "$CHANAKYA_DIR/vendor/ponytail/.cursor/rules/ponytail.mdc" "$REPO_ROOT/.cursor/rules/ponytail.mdc"
        ok "Original Ponytail rule installed."
      else
        bad "Could not find ponytail.mdc in the cloned repository."
      fi
    fi
  fi
  
  # 5. Local paths
  if [ ! -f "$CHANAKYA_DIR/repo-paths.properties" ]; then
    if confirm "Set up local source paths now?"; then
      cp "$CHANAKYA_DIR/templates/repo-paths.properties.template" "$CHANAKYA_DIR/repo-paths.properties"
      info "Template copied to .chanakya/repo-paths.properties. Please edit it manually."
    fi
  fi
  
  # 6. Agent permission gate
  echo
  if confirm "Print instructions for agent-led steps (canary, knowledge)?" "default_y"; then
    info "Next steps (run these in an Agent chat):"
    info "1. 'Build my canary.md from project files (e.g. pom.xml) using templates/canary.md'"
    info "2. 'Distill knowledge for [section] using templates/producer-prompt.md'"
  fi
  
  echo
  cmd_suggest_commit
  ok "Init complete."
}

# --- Dispatch ---------------------------------------------------------------------------------

case "${1:-help}" in
  doctor)   cmd_doctor ;;
  status)   cmd_status ;;
  assess)   cmd_assess ;;
  update)   cmd_update ;;
  update-framework) cmd_update_framework "${2:-0}" ;;
  enable)   cmd_enable ;;
  disable)  cmd_disable ;;
  suggest-commit) cmd_suggest_commit ;;
  uninstall) cmd_uninstall ;;
  version)
    if [ "${2:-}" = "bump" ]; then
      new_v=$(bump_version "${3:-patch}")
      ok "Bumped to $new_v"
    else
      get_version
    fi
    ;;
  produce)  cmd_produce "${2:-}" ;;
  scan)     cmd_scan ;;
  init)     cmd_init ;;
  *) echo "Chanakya CLI $(get_version)";
     echo "Usage: $0 <command>";
     echo "  doctor          verify prerequisites";
     echo "  init            setup framework";
     echo "  scan            reconcile artifacts";
     echo "  status          show project health";
     echo "  assess          calculate token footprint and benefit";
     echo "  produce         distill knowledge";
     echo "  update          run project health pass";
     echo "  update-framework [--check] pull framework updates";
     echo "  enable/disable  toggle framework governance";
     echo "  suggest-commit  see what to check in";
     echo "  uninstall       remove framework from project";
     echo "  version [bump]  show or increment version (major|minor|patch)" ;;
esac
